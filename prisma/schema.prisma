generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  password      String
  phone         String?
  avatarUrl     String?
  role          String        @default("user")
  googleId      String?       @unique
  authProvider  String        @default("email")
  isBanned      Boolean       @default(false)
  banReason     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  favorites     Favorite[]
  listings      Listing[]
  activityLogs  ActivityLog[]
  reviews       Review[]
  conversations1 Conversation[] @relation("ConvParticipant1")
  conversations2 Conversation[] @relation("ConvParticipant2")
  sentMessages      Message[] @relation("MessageSender")
  notifications     Notification[]
  resetToken        String?
  resetTokenExpiry  DateTime?
  isVerifiedAgent   Boolean       @default(false)
  agentBio          String?
  agentCompany      String?
  agentLicense      String?
  agentSpecialties  String        @default("[]")
  pushSubscription  String?
  pushEnabled       Boolean       @default(false)
}

model Listing {
  id           String    @id @default(cuid())
  title        String
  description  String
  price        Float
  priceUnit    String    @default("day")
  location     String
  category     String
  imageUrl     String
  imageUrls    String    @default("[]")
  tier         String    @default("standard")
  contactPhone String?
  contactEmail String?
  isFeatured   Boolean   @default(false)
  isApproved   Boolean   @default(true)
  status       String    @default("active")
  amenities    String    @default("[]")
  viewCount    Int       @default(0)
  inquiryCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  latitude     Float?
  longitude    Float?
  ownerId      String?
  owner        User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  favorites    Favorite[]
  categoryId   String?
  categoryRef  Category? @relation("ListingCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  conversations Conversation[]
  reviews        Review[]
}

model Review {
  id         String   @id @default(cuid())
  listingId  String
  userId     String
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([userId])
  @@unique([listingId, userId])
}

model Favorite {
  id        String   @id @default(cuid())
  listingId String
  sessionId String?
  userId    String?
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  icon      String    @default("Building2")
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  listings  Listing[] @relation("ListingCategory")
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  userId    String?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "new_message", "new_review", "listing_approved", "listing_rejected", "price_drop", "new_follower", "system"
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  ipAddress String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Conversation {
  id             String    @id @default(cuid())
  participant1Id String
  participant2Id String
  listingId      String?
  lastMessageAt  DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  participant1 User      @relation("ConvParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2 User      @relation("ConvParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  listing       Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  messages      Message[]

  @@index([participant1Id])
  @@index([participant2Id])
  @@index([lastMessageAt])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String?
  fileType       String?
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  isRead         Boolean   @default(false)
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([isRead])
  @@index([createdAt])
}
